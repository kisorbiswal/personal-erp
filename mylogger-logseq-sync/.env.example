# Absolute path to Logseq vault on host
LOGSEQ_VAULT_PATH=/home/butu/logseq-vault

# MyLogger API base + token
MYLOGGER_BASE_URL=https://logger-api.kisorbiswal.com
MYLOGGER_API_TOKEN=

# Owner/user namespace
MYLOGGER_USER=117245190

# Checkpoint DB path (inside container)
SYNC_STATE_DB=/app/sync_state.db

# OCR (optional)
OCR_INBOX_DIR=/vault/assets/ocr/incoming
OCR_ENABLED=false

# Search/index (optional)
QDRANT_URL=http://qdrant:6333
ENABLE_SEMANTIC_INDEX=false
