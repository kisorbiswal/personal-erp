generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Personal-only ERP (no workspaces / no sharing)
// Multi-account safe by default: every record is scoped to a User.

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events  Event[]
  tags   Tag[]
  boards Board[]
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventTags EventTag[]

  @@unique([userId, name])
  @@index([userId, name])
}

model Event {
  id         String   @id @default(cuid())
  userId     String

  occurredAt DateTime
  ingestedAt DateTime @default(now())

  content    String

  source     String?  // e.g. mylogger, telegram
  sourceRef  String?  // e.g. mylogger:info_list:123

  deletedAt  DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags     EventTag[]
  pinnedOn BoardPin[]

  @@index([userId, occurredAt])
  @@index([userId, deletedAt])
  @@index([userId, source, sourceRef])
}

model EventTag {
  id      String @id @default(cuid())
  eventId String
  tagId   String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([eventId, tagId])
  @@index([tagId])
}

model Board {
  id        String   @id @default(cuid())
  userId    String
  name      String
  position  Int      @default(0)
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pins BoardPin[]

  @@index([userId])
  @@unique([userId, name])
}

model BoardPin {
  id        String   @id @default(cuid())
  boardId   String
  eventId   String
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([boardId, eventId])
  @@index([eventId])
}
